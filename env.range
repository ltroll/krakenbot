# Apache order ledger
ORDER_TRACKER_URL=
ORDER_TRACKER_USER_AGENT=range-grid-bot/1.0

# Compatibility defaults for older scripts and the range-grid bot
BOT_CONFIG_FILE=range_grid_config.json
