RANGE_GRID_SELL_EXTENSION_SHADOW_ENABLED=true
RANGE_GRID_SELL_EXTENSION_SHADOW_COOLDOWN_MINUTES=120
RANGE_GRID_SELL_EXTENSION_SHADOW_MAX_AGE_MINUTES=360
