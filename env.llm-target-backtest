# Standalone LLM target snapshot capture and backtesting.
# Source this on the separate backtest host, or pass it to your service wrapper.

KRAKEN_PAIR=XXBTZUSD
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_TICKER_URL="https://api.kraken.com/0/public/Ticker?pair=XXBTZUSD"
KRAKEN_ORDERBOOK_URL="https://api.kraken.com/0/public/Depth?pair=XBTUSD&count=5"

# Use SIGNAL_FILE for a local JSON signal file, or LLM_SIGNAL_URL for HTTP.
SIGNAL_FILE=
LLM_SIGNAL_URL="http://screenpi.local/bot/multi_asset_signal.json"
TARGET_QUALITY_FILE="http://screenpi.local/bot/target_price_quality.json"
REQUEST_TIMEOUT_SECONDS=10

# Strategy used by capture snapshots and the standalone LLM bot.
LLM_TARGET_STRATEGY_PROFILE=llm_target_strategy_default.json
LLM_TARGET_STATE_FILE=llm_target_state.json
LLM_TARGET_TRADE_LOG_FILE=llm_target_trade_log.jsonl

# Snapshot capture.
LLM_TARGET_BACKTEST_SNAPSHOT_FILE=/var/www/html/bot/llm_target_backtest_snapshot_log.jsonl
LLM_TARGET_BACKTEST_ROTATE_DAILY=true
LLM_TARGET_BACKTEST_SNAPSHOT_RETENTION_DAYS=14

# Backtest report.
LLM_TARGET_BACKTEST_OUTPUT_FILE=/var/www/html/bot/llm_target_backtest.json
LLM_TARGET_BACKTEST_ARCHIVE_DIR=/var/www/html/bot
LLM_TARGET_BACKTEST_WINDOW_HOURS=24
LLM_TARGET_BACKTEST_ENTRY_WAIT_HOURS=4
LLM_TARGET_BACKTEST_MAX_HOLD_HOURS=24
LLM_TARGET_BACKTEST_STOP_LOSS_PCT=0.5
LLM_TARGET_BACKTEST_COOLDOWN_MINUTES=60
LLM_TARGET_BACKTEST_FEE_BPS=0.0
LLM_TARGET_BACKTEST_RECENT_LIMIT=25
LLM_TARGET_BACKTEST_DERIVE_TARGETS_FROM_QUALITY=true

# Strategy-file comparison.
LLM_TARGET_BACKTEST_STRATEGY_SET_FILE=llm_target_strategy_test_set.txt
LLM_TARGET_BACKTEST_STRATEGY_COMPARE_CSV_FILE=/var/www/html/bot/llm_target_strategy_comparison.csv
LLM_TARGET_BACKTEST_STRATEGY_RANKED_CSV_FILE=/var/www/html/bot/llm_target_strategy_ranked.csv

# Discount requirements used by sentiment-discount backtest variants.
LLM_TARGET_BACKTEST_SENTIMENT_DISCOUNT_WATCH_PCT=0.25
LLM_TARGET_BACKTEST_SENTIMENT_DISCOUNT_BEARISH_PCT=0.5
