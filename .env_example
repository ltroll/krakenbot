GRID_ANCHOR=median
RANGE_WINDOW_HOURS=24
MAX_GRID_SIZE=4
PROFIT_TARGET_PCT=0.009
ROUND_TRIP_FEE_PCT=0.0032
POSITION_SIZE_PCT=0.10
EXECUTION_SIGNAL_THRESHOLD=-2.00
PRICE_CHECK_INTERVAL_SECONDS=60
