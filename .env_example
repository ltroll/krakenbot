# Shared bot operation
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_TICKER_URL=https://api.kraken.com/0/public/Ticker?pair=XXBTZUSD
KRAKEN_ORDERBOOK_URL=https://api.kraken.com/0/public/Depth?pair=XBTUSD&count=5
KRAKEN_OHLC_URL=https://api.kraken.com/0/public/OHLC?pair=XBTUSD&interval=60
LLM_SIGNAL_URL=http://192.168.50.211/bot/multi_asset_signal.json
# Selects the asset from multi_asset_signal.json for this bot instance.
SIGNAL_ASSET_ID=BTC
BOT_POLICY_BACKTEST_URL=http://192.168.50.211/bot/bot_policy_backtest.json
BOT_REPLAY_BACKTEST_URL=http://192.168.50.211/bot/bot_replay_backtest.json
PRICE_LOG_URL=http://192.168.50.211/bot/btc_price_log.jsonl
BOT_DIR_LIST_FILE=/home/losttroll/tradingbot/bot_dirs.txt

# Compatibility defaults for older scripts and the range-grid bot
BOT_CONFIG_FILE=range_grid_config.json
BOT_STATE_FILE=last_state.json
TRADE_LOG_FILE=trade_log.jsonl

# Range-grid bot operation
RANGE_GRID_CONFIG_FILE=range_grid_config.json
RANGE_GRID_STATE_FILE=last_state.json
RANGE_GRID_TRADE_LOG_FILE=trade_log.jsonl
RANGE_GRID_TRADE_LOG_MAX_MB=50
RANGE_GRID_TRADE_LOG_RETENTION=8
RANGE_GRID_ACTIVITY_LOG_FILE=/var/www/html/bot/range_grid_activity.jsonl
RANGE_GRID_ACTIVITY_LOG_ROTATE_DAILY=true
RANGE_GRID_BACKTEST_HTTP_TIMEOUT_SECONDS=10
RANGE_GRID_STRATEGY_PROFILE=range_grid_strategy_default.json
RANGE_GRID_BACKTEST_ANCHOR_WINNERS_FILE=range_grid_anchor_winners.json
RANGE_GRID_BACKTEST_ANCHOR_WINNER_MIN_APPROVED=1
RANGE_GRID_BACKTEST_ANCHOR_WINNER_MIN_AVG_END_RETURN_PCT=0
RANGE_GRID_BACKTEST_ANCHOR_WINNER_MAX_AVG_DRAWDOWN_PCT=-3
# Optional: rewrite winner strategy_file paths for the production box.
RANGE_GRID_BACKTEST_ANCHOR_WINNER_STRATEGY_DIR=
# Off by default. Enable only after reviewing range_grid_anchor_winners.json.
RANGE_GRID_ANCHOR_ROUTER_ENABLED=false
RANGE_GRID_ANCHOR_ROUTER_FILE=range_grid_anchor_winners.json
RANGE_GRID_ANCHOR_ROUTER_TIMEOUT_SECONDS=5

# Standalone LLM target bot operation
LLM_TARGET_STRATEGY_PROFILE=llm_target_strategy_default.json
LLM_TARGET_STATE_FILE=llm_target_state.json
LLM_TARGET_TRADE_LOG_FILE=llm_target_trade_log.jsonl
LLM_TARGET_BACKTEST_STRATEGY_SET_FILE=llm_target_strategy_test_set.txt
LLM_TARGET_BACKTEST_STRATEGY_COMPARE_CSV_FILE=llm_target_strategy_comparison.csv
LLM_TARGET_BACKTEST_STRATEGY_RANKED_CSV_FILE=llm_target_strategy_ranked.csv

# Sentiment executor operation
SENTIMENT_CONFIG_FILE=sentiment_bot_config.json
SENTIMENT_STATE_FILE=sentiment_state.json
SENTIMENT_TRADE_LOG_FILE=sentiment_trade_log.jsonl
SENTIMENT_TRADE_LOG_MAX_MB=50
SENTIMENT_TRADE_LOG_RETENTION=8
SENTIMENT_TRADE_ACTIVITY_FILE=sentiment_trade_activity.jsonl
SENTIMENT_DECISION_CSV_FILE=sentiment_decisions.csv
SENTIMENT_STRATEGY_PROFILE=sentiment_strategy_default.json
KRAKEN_PAIR=XXBTZUSD
SIGNAL_FILE=
REQUEST_TIMEOUT_SECONDS=10
REQUEST_RETRY_ATTEMPTS=2
REQUEST_RETRY_BACKOFF_SECONDS=1.5
ORDER_TRACKER_URL=
ORDER_TRACKER_USER_AGENT=
ORDER_TRACKER_SYMBOL=XXBTZUSD
ORDER_TRACKER_TIMEOUT_SECONDS=5
ORDER_TRACKER_CHECKIN_TIMEOUT_SECONDS=5
KRAKEN_NONCE_RETRIES=2
KRAKEN_LOCKOUT_COOLDOWN_SECONDS=300

# Optional backtest gate controls.
# The gate is disabled unless enabled here or with --backtest-health-gate.
# USE_BACKTEST_HEALTH_GATE=true
# BACKTEST_FAIL_CLOSED=true
# BACKTEST_MIN_TRADES=5
# BACKTEST_REQUIRE_POLICY_BEATS_BASELINE=true
# BACKTEST_USD=50
# SENTIMENT_RUN_BACKTEST=false

# Optional one-shot test buy sizing for --buynow.
# BUYNOW_USD=25

# Optional sentiment entry pacing.
# Prevents clustering several buys around the same price in a short window.
# ENTRY_PACING_ENABLED=true
# ENTRY_PACING_WINDOW_MINUTES=120
# ENTRY_PACING_MAX_BUYS=2
# ENTRY_PACING_MIN_PRICE_MOVE_PCT=0.005

# Optional legacy sentiment open-order caps.
# Disabled by default; max_inventory_usd and entry pacing are the primary
# exposure controls. Set true only if you want old max-open-order hard blocks.
# ENFORCE_OPEN_ORDER_LIMITS=false

# Optional sentiment trade activity ledger.
# This is separate from SENTIMENT_TRADE_LOG_FILE and records the real order
# lifecycle plus optional shadow buy plans for what-if/API-divergence checks.
# SENTIMENT_TRADE_ACTIVITY_FILE=sentiment_trade_activity.jsonl
# SENTIMENT_SHADOW_TRADES_ENABLED=false

# Optional sentiment-bot local snapshot/replay backtesting.
# Intended shape:
# - prod bot host runs sentiment_backtest_collector.py on a light cron
# - a separate reporting/backtest host runs sentiment_bot_backtest.py against
#   copied, mounted, or HTTP-hosted snapshot JSONL files
# Collector does not call Kraken private APIs.
# SENTIMENT_BACKTEST_SNAPSHOT_FILE=/var/www/html/bot/sentiment_backtest_snapshot_log.jsonl
# SENTIMENT_BACKTEST_ROTATE_DAILY=true
# SENTIMENT_BACKTEST_SNAPSHOT_RETENTION_DAYS=14
# SENTIMENT_BOT_BACKTEST_OUTPUT_FILE=/var/www/html/bot/sentiment_bot_local_backtest.json
# SENTIMENT_BOT_BACKTEST_HTTP_TIMEOUT_SECONDS=10

# Optional sentiment bot weather/risk-context controls.
# When risk_context.weather_report is present and fresh, the engine is advisory:
# the bot keeps trade authority, applies weather tuning multipliers, and only
# treats weather_emergency_bell as a hard pause.
# USE_RISK_CONTEXT_POLICY=true
# RISK_CONTEXT_HARD_SAFETY_BLOCK=false
# RISK_CONTEXT_MIN_BUY_SCORE=0.50  # Legacy risk-context fallback only.
# RISK_CONTEXT_POSITION_SIZE_ENABLED=true
# RISK_CONTEXT_TARGET_PROFIT_ENABLED=true
# RISK_CONTEXT_MAX_POSITION_SIZE_MULTIPLIER=1.25

# Optional high-entry quality controls.
# These do not disable buying globally. They only require stronger confirmation
# before a market buy near recent/range highs; target-limit pullback entries are
# still allowed through their own gates.
# HIGH_ENTRY_QUALITY_ENABLED=true
# HIGH_ENTRY_RANGE_POSITION_MIN=0.90
# HIGH_ENTRY_DISTANCE_TO_HIGH_PCT=0.75
# HIGH_ENTRY_MAX_MARKET_RISK_SCORE=0.35
# HIGH_ENTRY_MIN_CONFIRMATION_SCORE=0.65
# HIGH_ENTRY_REQUIRE_POSITIVE_4H_RETURN=true
# HIGH_ENTRY_SIZE_MULTIPLIER=0.50

# Optional market-entry quality controls.
# These slow down eager market buys in middle/upper range unless weather/risk
# context confirms a better setup. Low-range entries remain easier to take.
# MARKET_ENTRY_QUALITY_ENABLED=true
# MARKET_ENTRY_FREE_RANGE_POSITION_MAX=0.25
# MARKET_ENTRY_REQUIRE_CONFIRMATION_ABOVE_RANGE=0.25
# MARKET_ENTRY_MIN_BUY_SCORE=0.50
# MARKET_ENTRY_MIN_REBOUND_SCORE=0.55
# MARKET_ENTRY_MIN_BOTTOMING_SCORE=0.55
# MARKET_ENTRY_REQUIRE_POSITIVE_4H_RETURN=false
# MARKET_ENTRY_DIP_PHASES=dip_leveling_entry,early_rebound
# MARKET_ENTRY_AVOID_PHASES=peak_exhaustion_watch,pullback_wait,storm_avoid,range_chop_downtrend,range_chop_distribution
# MARKET_ENTRY_MIN_OPPORTUNITY_SCORE=0.67
# MARKET_ENTRY_MIN_REBOUND_CONFIRMATION_SCORE=0.55
# MARKET_ENTRY_DIP_SIZE_MULTIPLIER=0.50
# MARKET_ENTRY_GENERIC_PHASES=range_chop_stabilizing,range_chop_accumulation
# MARKET_ENTRY_STRICT_PHASE_MATCH=true
# MARKET_ENTRY_BLOCK_FALLING_TAPE=true
# MARKET_ENTRY_MIN_STABILIZATION_SCORE=0.65
# MARKET_ENTRY_DIP_MIN_STABILIZATION_SCORE=0.55
# MARKET_ENTRY_REBOUND_MIN_STABILIZATION_SCORE=0.60
# MARKET_ENTRY_MAX_FAILED_REBOUND_RISK=0.65
# MARKET_ENTRY_MAX_LONG_ENTRY_NOISE_RISK=0.65

# Optional LLM target bot production guards. Zero/blank disables each guard.
# LLM_TARGET_DERIVE_TARGETS_FROM_QUALITY=true
# LLM_TARGET_KILL_SWITCH_FILE=/var/www/html/bot/llm_target_disable
# LLM_TARGET_MAX_DAILY_REALIZED_LOSS_USD=25
# LLM_TARGET_MAX_CONSECUTIVE_LOSING_SELLS=2

# Optional daily backtesting report runner.
# BACKTEST_REPORT_DIR=/var/www/html/bot/backtesting_reports
# BACKTEST_SCRIPT_DIR=/home/ben/sentiment_engine
# BACKTEST_REPORT_HOURS=24
# BACKTEST_PYTHON=/usr/bin/python3
# BOT_POLICY_BACKTEST_URL=http://screenpi.local/bot/bot_policy_backtest.json
# BOT_REPLAY_BACKTEST_URL=http://screenpi.local/bot/bot_replay_backtest.json
# SIGNAL_FORWARD_BACKTEST_URL=http://screenpi.local/bot/signal_forward_backtest.json
# BOT_POLICY_BACKTEST_OUTPUT_FILE=/var/www/html/bot/bot_policy_backtest.json
# BOT_REPLAY_BACKTEST_OUTPUT_FILE=/var/www/html/bot/bot_replay_backtest.json
# SIGNAL_FORWARD_BACKTEST_OUTPUT_FILE=/var/www/html/bot/signal_forward_backtest.json
# BACKTEST_TAKE_PROFIT_PCT=0.5
# BACKTEST_STOP_LOSS_PCT=0.5
# BACKTEST_ENTRY_WAIT_HOURS=4
# BACKTEST_MAX_HOLD_HOURS=24
# BACKTEST_COOLDOWN_MINUTES=60
# BACKTEST_FEE_BPS=0
# BACKTEST_REPORT_INCLUDE_RAW_LOG=true
